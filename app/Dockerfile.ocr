FROM python:3.11-slim

# OpenCV runtime deps commonly needed on slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    libglib2.0-0 \
 && rm -rf /var/lib/apt/lists/*

RUN useradd --system --uid 10001 --shell /usr/sbin/nologin appuser

WORKDIR /app

COPY requirements_ocr.txt /app/requirements_ocr.txt
RUN pip install --no-cache-dir -r /app/requirements_ocr.txt

COPY glm_ocr_ollama.py /app/glm_ocr_ollama.py

USER 10001:10001

ENTRYPOINT ["python", "/app/glm_ocr_ollama.py"]
