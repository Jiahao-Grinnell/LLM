*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
coverage.xml
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
ENV/
env/

# -------------------------
# Build / packaging
# -------------------------
build/
dist/
*.whl

